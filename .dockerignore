# Ignore files and folders not needed in Docker build context

# 🔹 Documentation and examples
README.md
HELP_RRULE.md
HELP_SMTP.md
LICENSE

# 🔹 Dev tools and configs
.dockerignore
.gitignore
.env.example
docker-compose.sample.yml

__pycache__/
*.pyc

# 🔹 Data & user uploads (mounted at runtime)
uploads/*
!uploads/.keep
data/*
!data/.keep
data/backups/*
!data/backups/.keep

# Exclude all Python files in tools
tools/*

# Re-include reset_admin_password.py
!tools/reset_admin_password.py

# 🔹 Local-only scripts and tooling
screenshots/

# 🔹 Local-only build cache
.buildx-cache/

# 🔹 Git history
.git/

# 🔹 Unused scripts/docs
release_notes/
scripts/generate_screenshots.py
scripts/copy_fonts_from_node_modules.py
tools/pa11y_*
tools/summarize_*
tools/lighthouse_*

# 🔹 Testing
tests/
htmlcov/
.pytest_cache/
*.coverage

# 🔹 Node build artifacts
node_modules/
dist/
build/
tailwind.config.js
postcss.config.js

# 🔹 Logs, tmp, and misc
*.log
*.bak
*.tmp
*.orig
