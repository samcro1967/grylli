#: /home/osuhickeys/Documents/Docker/grylli/app/templates/index.html:36
msgid "Set your check-in interval and grace period."
msgstr "Stel jou tjekinterval en grasietydperk."

#: /home/osuhickeys/Documents/Docker/grylli/app/templates/index.html:37
msgid "Assign one or more delivery destinations."
msgstr "Ken een of meer afleweringsbestemmings toe."

#: /home/osuhickeys/Documents/Docker/grylli/app/templates/index.html:38
msgid "Optionally attach files for secure emails."
msgstr "Heg opsioneel lêers aan vir veilige e-posse."

#: /home/osuhickeys/Documents/Docker/grylli/app/templates/index.html:39
msgid "Enable the message to start monitoring."
msgstr "Skakel die boodskap aan om te begin monitor."

#: /home/osuhickeys/Documents/Docker/grylli/app/templates/index.html:40
msgid "If you don’t check in, Grylli delivers the message for you."
msgstr "As jy nie inklok nie, lewer Grylli die boodskap vir jou af."

