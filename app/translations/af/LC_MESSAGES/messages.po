#: /home/osuhickeys/Documents/Docker/grylli/app/templates/about.html:14
msgid "About Grylli"
msgstr "Oor Grylli"

#: /home/osuhickeys/Documents/Docker/grylli/app/templates/about.html:19
msgid ""
"Grylli is a secure message delivery platform designed to activate after "
"prolonged user inactivity."
msgstr ""
"Grylli is 'n veilige boodskapafleweringsplatform ontwerp om te aktiveer na "
"langdurige gebruiker inaktiwiteit."

#: /home/osuhickeys/Documents/Docker/grylli/app/templates/about.html:20
msgid ""
"It is a modern reimplementation of Gone Man’s Switch with a refined tech "
"stack, better maintainability, and an improved user experience."
msgstr ""
"Dit is 'n moderne herimplementering van Gone Man's Switch met 'n verfynde "
"tegnologie-stapel, beter onderhoudbaarheid, en 'n verbeterde "
"gebruikerervaring."

#: /home/osuhickeys/Documents/Docker/grylli/app/templates/about.html:26
