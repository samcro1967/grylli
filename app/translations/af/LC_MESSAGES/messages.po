#: /home/osuhickeys/Documents/Docker/grylli/app/templates/index.html:14
#: /home/osuhickeys/Documents/Docker/grylli/app/views/locale.py:68
msgid "Welcome to Grylli"
msgstr "Welkom by Grylli"

#: /home/osuhickeys/Documents/Docker/grylli/app/templates/index.html:17
msgid "Pronounced"
msgstr "Uitgespreek"

#: /home/osuhickeys/Documents/Docker/grylli/app/templates/index.html:17
msgid "like “grill-ee”"
msgstr "soos “grill-ee”"

#: /home/osuhickeys/Documents/Docker/grylli/app/templates/index.html:22
msgid ""
"Grylli is a secure message scheduling and delivery system designed to ensure"
" your important messages are delivered — even if you can’t be there to send "
"them."
msgstr ""
"Grylli is 'n veilige boodskap skedulering en afleweringstelsel ontwerp om te"
" verseker jou belangrike boodskappe word afgelewer — selfs al kan jy nie "
"daar wees om dit te stuur nie."

#: /home/osuhickeys/Documents/Docker/grylli/app/templates/index.html:27
msgid ""
"Whether you’re planning ahead, setting up emergency communication, or "
"building peace of mind, Grylli helps automate your message delivery via "
"email, webhooks, or Apprise notifications if you miss a check-in."
msgstr ""
"Of jy nou vooruit beplan, noodkommunikasie opstel, of ekstra gemoedsrus "
"opbou, Grylli help jou om boodskapaflewering via e-pos, webhooks, of Apprise"
" kennisgewings te outomatiseer as jy 'n tjek mis."

