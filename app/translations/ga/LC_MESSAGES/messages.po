#: app/templates/admin/partials/help_panel.html:14
msgid "Click ✏️ to edit a user's information."
msgstr "Cliceáil ✏️ le haghaidh faisnéis úsáideora a chur in eagar."

#: app/templates/admin/partials/help_panel.html:15
msgid "Click 🗑️ to delete a user (confirmation required)."
msgstr "🧪 Theip ar theip an fógra tástála a sheoladh:"

#: app/templates/admin/partials/help_panel.html:17
msgid "Click 🔴 or 🟢 to disable or enable a user account."
msgstr "Chun úsáideoir a dhíchumasú nó a chumasú, cliceáil 🔴 nó 🟢."

#: app/templates/admin/partials/help_panel.html:19
msgid "🟢 = Active: user can log in."
msgstr "🟢 = Tá an t-úsáideoir cumasaithe agus is féidir leis logáil isteach."

#: app/templates/admin/partials/help_panel.html:20
msgid "🔴 = Disabled: user is locked out."
msgstr "🔴 = Dímheasta: tá an t-úsáideoir faoi ghlas."

#: app/templates/admin/partials/help_panel.html:21
msgid "⚪ = You cannot disable your own admin account."
msgstr "⚪ = Ní féidir leat do chuntas féin a dhíchumasú."

#: app/templates/admin/partials/help_panel.html:24
msgid "Click 🛡️ to change a user’s role (admin ↔ user)."
msgstr "Chun ról úsáideora a athrú, cliceáil 🛡️."

#: app/templates/admin/partials/help_panel.html:25
msgid "Click 🔑 to reset MFA (only shown if MFA is active for that user)."
msgstr ""
"Chun MFA a athshocrú, cliceáil 🔑 (nach bhfeictear ach má chuirtear MFA ar "
"fáil)."

#: app/templates/admin/partials/help_panel.html:27
msgid ""
"Accounts are automatically locked after repeated failed login attempts."
msgstr ""
"Tá cuntais faoi ghlas go huathoibríoch tar éis iarrachtaí logála isteach "
"mainneacha leanúnacha."

#: app/templates/admin/partials/help_panel.html:28
msgid "To unlock an account immediately, click 🔓 next to the user’s row."
msgstr ""
"Chun cuntas a dhíghlasáil láithreach, cliceáil 🔓 in aice le ró an úsáideora."

#: app/templates/admin/partials/help_panel.html:29
msgid "Accounts will also unlock automatically after a short delay."
msgstr ""
"Ní mór do chuntais a dhíghlasáil go huathoibríoch tar éis moill ghearr."

#: app/templates/admin/partials/help_panel.html:31
msgid ""
"All actions are logged for accountability. Passwords and secrets are never "
"visible."
msgstr ""
"Tá gach gníomh logáilte le haghaidh cuntasachta. Ní fheictear pasfhocail "
"agus rúin riamh."

