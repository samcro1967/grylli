#: app/templates/about.html:10 app/templates/index.html:14
#: app/views/locale.py:107
msgid "Welcome to Grylli"
msgstr "Bem-vindo ao Grylli"

#: app/templates/about.html:13 app/templates/index.html:16
msgid "Pronounced"
msgstr "Pronunciado"

#: app/templates/about.html:13 app/templates/index.html:16
msgid "like “grill-ee”"
msgstr "como \"grill-ee\""

#: app/templates/about.html:17
msgid ""
"Grylli is a secure message scheduling and delivery system designed to ensure"
" your important messages are sent — even if you’re unable to check in."
msgstr ""
"Grylli é um sistema de agendamento e entrega de mensagens seguras projetado "
"para garantir que suas mensagens importantes sejam entregues — mesmo se você"
" não puder estar lá para enviá-las."

#: app/templates/about.html:20
msgid ""
"With support for email, webhooks, and over 100 third-party services via "
"Apprise, Grylli gives you full control over how and when messages are "
"delivered."
msgstr ""
"Com suporte para e-mail, webhooks e mais de 100 serviços de terceiros via "
"Apprise, o Grylli oferece controle total sobre como e quando as mensagens "
"são entregues."

#: app/templates/about.html:21
msgid ""
"You can also configure your own SMTP settings to ensure messages appear to "
"come from your personal address."
msgstr ""
"Você também pode configurar suas próprias configurações SMTP para garantir "
"que as mensagens pareçam vir do seu endereço pessoal."

#: app/templates/about.html:24 app/templates/index.html:24
msgid "Getting Started"
msgstr "Começando"

#: app/templates/about.html:26
msgid "Create a message, email, or reminder."
msgstr "Crie uma mensagem ou email."

#: app/templates/about.html:27
msgid "Set a check-in interval and grace period for your messages."
msgstr "Defina seu intervalo de check-in e período de carência."

#: app/templates/about.html:28
msgid "Choose one or more delivery destinations (email, webhook, Apprise)."
msgstr "Atribua um ou mais destinos de entrega."

#: app/templates/about.html:29
msgid "Attach optional files for email delivery."
msgstr "Anexe quaisquer arquivos opcionais (se necessário)."

#: app/templates/about.html:30
msgid "Use test-send to validate your destination setup."
msgstr "Use test-send para validar sua configuração de destino."

#: app/templates/about.html:31
msgid "Schedule your reminder: once, daily, weekly, or custom."
msgstr ""
"Agende seu lembrete: uma vez, diariamente, semanalmente ou personalizado."

#: app/templates/about.html:32
msgid "Enable the item to activate automatic delivery logic."
msgstr "Ative a mensagem ou lembrete para ativar a entrega."

#: app/templates/about.html:33
msgid "Check in regularly to prevent automated sends."
msgstr "Verifique regularmente para prevenir envios automáticos."

#: app/templates/about.html:37
msgid ""
"Your data is encrypted at rest, messages are only sent if you miss a check-"
"in, and you can export or delete your account at any time."
msgstr ""
"Seus dados são criptografados em repouso, mensagens são enviadas apenas se "
"você perder um check-in, e você pode exportar ou excluir sua conta a "
"qualquer momento."

#: app/templates/help.html:7
#: app/templates/partials/profile_dropdown_menu.html:46
msgid "Help"
msgstr "Ajuda"

#: app/templates/help.html:11
msgid "Help & Overview"
msgstr "Visão Geral"

#: app/templates/help.html:13
msgid ""
"Grylli helps you schedule messages, emails, and reminders that are sent "
"automatically if you fail to check in on time."
msgstr ""
"Grylli ajuda a agendar mensagens, e-mails e lembretes que são enviados "
"automaticamente se você não fizer check-in a tempo."

#: app/templates/help.html:14
msgid ""
"It supports multiple delivery methods, user-level SMTP, rich scheduling, and"
" secure data handling."
msgstr ""
"Suporta múltiplos métodos de entrega, SMTP a nível de usuário, agendamento "
"avançado e manuseio seguro de dados."

#: app/templates/help.html:17
msgid "Key Areas"
msgstr "Áreas Chave"

#: app/templates/help.html:20
msgid "Messages"
msgstr "Mensagem salva."

#: app/templates/help.html:21
msgid ""
"Configure notifications to be sent if you miss a check-in. Supports check-in"
" intervals, grace periods, and multiple destinations."
msgstr ""
"Configure notificações para serem enviadas se você perder um check-in. "
"Suporta intervalos de check-in, períodos de carência e múltiplos destinos."

#: app/templates/help.html:24 app/templates/partials/shared_nav.html:82
#: app/templates/reminders/list_reminders.html:15
msgid "Reminders"
msgstr "minutos"

#: app/templates/help.html:25
msgid ""
"Schedule single or recurring reminders without requiring a check-in. Useful "
"for fixed-date messages."
msgstr ""
"Agende lembretes únicos ou recorrentes sem exigir um check-in. Útil para "
"mensagens com data fixa."

#: app/templates/email/list_emails.html:15 app/templates/help.html:28
#: app/templates/partials/shared_nav.html:50
msgid "Emails"
msgstr "Emails"

#: app/templates/help.html:29
msgid ""
"Send secure emails with optional file attachments. Emails can be used with "
"both messages and reminders."
msgstr ""
"Envie e-mails seguros com anexos de arquivo opcionais. Os e-mails podem ser "
"usados com mensagens e lembretes."

#: app/templates/admin/index.html:27 app/templates/help.html:32
#: app/templates/partials/admin_nav.html:50
msgid "SMTP Settings"
msgstr "Configurações SMTP"

#: app/templates/help.html:33
msgid ""
"Configure your own email credentials for personalized delivery. Each user "
"can define their own SMTP server."
msgstr ""
"Configure suas próprias credenciais de e-mail para entrega personalizada. "
"Cada usuário pode definir seu próprio servidor SMTP."

#: app/templates/apprise/apprise_config.html:11
#: app/templates/apprise/list_apprise.html:14 app/templates/help.html:36
#: app/templates/messages/assign_destinations.html:22
#: app/templates/reminders/assign_destinations.html:20
msgid "Apprise Destinations"
msgstr "Destinos Apprise"

#: app/templates/help.html:37
msgid ""
"Send notifications to 80+ third-party services like Pushover, Gotify, "
"Discord, Slack, and more."
msgstr ""
"Envie notificações para mais de 80 serviços de terceiros como Pushover, "
"Gotify, Discord, Slack e outros."

#: app/templates/help.html:40
#: app/templates/messages/assign_destinations.html:41
#: app/templates/messages/view_message.html:60
#: app/templates/partials/shared_nav.html:40
#: app/templates/reminders/assign_destinations.html:39
#: app/templates/reminders/view_reminder.html:72
msgid "Webhooks"
msgstr "Webhooks"

#: app/templates/help.html:41
msgid ""
"Trigger an HTTP POST to an external service or automation tool when a "
"message is delivered."
msgstr ""
"Acione um HTTP POST para um serviço externo ou ferramenta de automação "
"quando uma mensagem for entregue."

#: app/templates/help.html:44
msgid "Test Send"
msgstr "Último Check-in"

#: app/templates/help.html:45
msgid ""
"Quickly verify that your destinations (email, webhook, Apprise) are working "
"as expected."
msgstr ""
"Verifique rapidamente se seus destinos (e-mail, webhook, Apprise) estão "
"funcionando como esperado."

#: app/templates/help.html:48
#: app/templates/partials/profile_dropdown_menu.html:16
msgid "Security"
msgstr "🔐 Segurança"

#: app/templates/help.html:49
msgid ""
"All sensitive credentials are encrypted at rest. Your messages are only sent"
" if you fail to check in."
msgstr ""
"Todas as credenciais sensíveis são criptografadas em repouso. Suas mensagens"
" são enviadas apenas se você não fizer check-in."

#: app/templates/help.html:54
msgid ""
"Need help with something specific? Each module in Grylli includes its own "
"help panel with detailed guidance."
msgstr ""
"Precisa de ajuda com algo específico? Cada módulo no Grylli inclui seu "
"próprio painel de ajuda com orientações detalhadas."

#: app/templates/index.html:11
msgid "⚠️ Grylli is not using a secure HTTPS connection."
msgstr "⚠️ Gryllis não está usando uma conexão HTTPS segura."

#: app/templates/index.html:12
msgid "Data is not encrypted in transit across the network."
msgstr "Os dados não estão criptografados durante a transmissão pela rede."

#: app/templates/index.html:19
msgid ""
"Grylli is a secure message scheduling and delivery system designed to ensure"
" your important messages are delivered — even if you can’t be there to send "
"them."
msgstr ""
"Grylli é um sistema de agendamento e entrega de mensagens seguras projetado "
"para garantir que suas mensagens importantes sejam entregues — mesmo se você"
" não puder estar lá para enviá-las."

#: app/templates/index.html:22
msgid ""
"Whether you’re planning ahead, setting up emergency communication, or "
"building peace of mind, Grylli helps automate your message delivery via "
"multiple channels including email, webhooks, and Apprise notifications."
msgstr ""
"Seja planejando com antecedência, configurando comunicação de emergência ou "
"buscando tranquilidade, o Grylli ajuda a automatizar sua entrega de "
"mensagens via email, webhooks ou notificações Apprise se você perder um "
"check-in."

#: app/templates/index.html:26
msgid "Create a notification, email, or reminder."
msgstr "Crie uma mensagem ou email."

#: app/templates/index.html:27
msgid ""
"Set your check-in interval and grace period for notifications and emails."
msgstr "Defina seu intervalo de check-in e período de carência."

#: app/templates/index.html:28
msgid "Assign one or more delivery destinations."
msgstr "Atribua um ou mais destinos de entrega."

#: app/templates/index.html:29
msgid "Optionally attach files for emails."
msgstr "Opcionalmente anexe arquivos para emails seguros."

#: app/templates/index.html:30
msgid "Schedule reminders to send at specific times or on a recurring basis."
msgstr ""
"Agendar lembretes para enviar em horários específicos ou de forma "
"recorrente."

#: app/templates/index.html:31
msgid "Enable the notification, email, or reminder to activate delivery."
msgstr "Ative a mensagem ou lembrete para ativar a entrega."

#: app/templates/index.html:33
msgid ""
"Regularly check in to Grylli to prevent automated delivery; miss a check-in "
"and Grylli sends your messages as scheduled."
msgstr ""
"Entre regularmente no Grylli para evitar a entrega automatizada; perca um "
"check-in e o Grylli envia suas mensagens conforme programado."

#: app/templates/privacy.html:11
msgid "Privacy Notice"
msgstr "Aviso de Privacidade"

#: app/templates/privacy.html:14
msgid ""
"Grylli respects your privacy and is designed to minimize the collection and "
"storage of personal data."
msgstr ""
"Grylli respeita sua privacidade e foi projetado para minimizar a coleta e "
"armazenamento de dados pessoais."

#: app/templates/privacy.html:15
msgid ""
"All sensitive data (including passwords, tokens, and MFA secrets) is "
"encrypted at rest, and remains fully under your control if you self-host "
"this platform."
msgstr ""
"Todos os dados são criptografados quando apropriado e permanecem totalmente "
"sob seu controle se você hospedar esta plataforma."

#: app/templates/privacy.html:18
msgid "What Data We Collect"
msgstr "Quais Dados Coletamos"

#: app/templates/privacy.html:20
msgid "Email address and password hash (for authentication)"
msgstr "Endereço de email e hash da senha (para autenticação)"

#: app/templates/privacy.html:21
msgid "Optional MFA secret and recovery codes (encrypted at rest)"
msgstr ""
"Código MFA opcional e códigos de recuperação (criptografados em repouso)"

#: app/templates/privacy.html:22
msgid "Reminder and message content you configure"
msgstr "Conteúdo de lembretes e mensagens que você configurar"

#: app/templates/privacy.html:23
msgid "User-specific settings and preferences"
msgstr "Configurações e preferências específicas do usuário"

#: app/templates/privacy.html:24
msgid "SMTP configuration (if provided)"
msgstr "Configuração SMTP atribuída."

#: app/templates/privacy.html:25
msgid "Third-party notification tokens (e.g., Apprise, Gotify, Pushover)"
msgstr ""
"Tokens de notificação de terceiros (por exemplo, Apprise, Gotify, Pushover)"

#: app/templates/privacy.html:26
msgid "Webhook URLs and configuration settings"
msgstr "URLs de Webhook e configurações de configuração"

#: app/templates/privacy.html:29
msgid "How Your Data Is Used"
msgstr "Como Seus Dados São Usados"

#: app/templates/privacy.html:31
msgid ""
"Your data is used solely for the purpose of delivering reminders and "
"messages according to your preferences."
msgstr ""
"Seus dados são usados apenas para o propósito de entregar lembretes e "
"mensagens de acordo com suas preferências."

#: app/templates/privacy.html:32
msgid ""
"Grylli does not share, sell, or transmit your personal data to any third "
"parties."
msgstr ""
"Grylli não compartilha, vende ou transmite seus dados pessoais a terceiros."

#: app/templates/privacy.html:36
msgid ""
"Sensitive fields like passwords and tokens are only stored if you provide "
"them explicitly. Existing values are never exposed unless you choose to "
"reveal them."
msgstr ""
"Campos sensíveis como senhas e tokens são armazenados apenas se você "
"fornecê-los explicitamente. Valores existentes nunca são expostos a menos "
"que você escolha revelá-los."

#: app/templates/privacy.html:38
msgid "Grylli contains no external analytics, telemetry, or tracking scripts."
msgstr ""
"Grylli não contém análises externas, telemetria ou scripts de rastreamento."

#: app/templates/privacy.html:41
msgid "Your Rights"
msgstr "Seus Direitos"

#: app/templates/privacy.html:43
msgid ""
"You can export all of your data at any time from the Account Settings page."
msgstr ""
"Você pode exportar todos os seus dados a qualquer momento na página de "
"Configurações de Conta."

#: app/templates/privacy.html:44
msgid "You may permanently delete your account and all associated data."
msgstr "Você não pode excluir sua conta porque é o último administrador."

#: app/templates/privacy.html:45
msgid ""
"If you are using a self-hosted instance, contact the instance administrator "
"for data inquiries."
msgstr ""
"Se você estiver usando uma instância autogerida, entre em contato com o "
"administrador da instância para dúvidas sobre dados."

#: app/templates/privacy.html:48
msgid "Self-Hosting Responsibility"
msgstr "Responsabilidade de Auto-Hospedagem"

#: app/templates/privacy.html:50
msgid ""
"When you self-host Grylli, you are responsible for ensuring all user data is"
" stored and processed in compliance with applicable privacy regulations."
msgstr ""
"Quando você auto-hospeda o Grylli, você é responsável por garantir que todos"
" os dados do usuário sejam armazenados e processados em conformidade com as "
