#: app/templates/admin/index.html:9
msgid "Admin Panel"
msgstr "Panel Admin"

#: app/templates/admin/index.html:11
msgid ""
"Welcome to the Grylli Admin Panel. Use the tools below to manage users, "
"configuration, and infrastructure-related settings."
msgstr ""
"Selamat datang di Panel Admin Grylli. Gunakan tautan di bawah ini untuk "
"mengelola sistem."

#: app/templates/admin/index.html:15
msgid "Manage Users"
msgstr "Kelola Pengguna"

#: app/templates/admin/index.html:16
msgid ""
"Create, edit, enable/disable, or delete user accounts. Control MFA, roles, "
"and recovery access."
msgstr "Buat, edit, aktif/nonaktifkan, atau hapus akun pengguna."

#: app/templates/admin/index.html:19
#: app/templates/admin/system_settings.html:9
#: app/templates/partials/admin_nav.html:45
