msgid "Please correct the errors below."
msgstr "لطفاً خطاهای زیر را تصحیح کنید."

#: app/views/reminders.py:481 app/views/reminders.py:482
msgid "None"
msgstr "خیر"

#: app/views/reminders.py:508
msgid "You must select both an SMTP config and an email message, or neither."
msgstr ""
"باید یک تنظیمات SMTP و یک پیام ایمیل را انتخاب کنید، یا هیچ‌کدام را انتخاب "
"نکنید."

#: app/views/reminders.py:528
msgid "Email reminder settings updated."
msgstr "مقاصد به‌روزرسانی شدند."

