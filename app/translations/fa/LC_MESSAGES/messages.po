msgstr "رمز عبور در هنگام ایجاد کاربر جدید لازم است."

#: app/views/users.py:244
msgid "Username already exists."
msgstr "نام کاربری از قبل موجود است."

#: app/views/users.py:251
msgid "Email already exists."
msgstr "ایمیل از قبل موجود است."

#: app/views/users.py:268
#, python-format
msgid "User '%(username)s' created successfully."
msgstr "کاربر '%(username)s' با موفقیت ایجاد شد."

#: app/views/users.py:278
msgid "Failed to create user."
msgstr "ایجاد کاربر شکست خورد."

#: app/views/users.py:305
msgid "You cannot change your own enabled status."
msgstr "شما نمی‌توانید وضعیت فعال خود را تغییر دهید."

#: app/views/users.py:318
#, python-format
msgid "User '%(username)s' has been %(status)s."
msgstr "وضعیت کاربر '%(username)s' به %(status)s تغییر یافت."

#: app/views/users.py:356
msgid "You cannot reset your own MFA."
msgstr "⚪ = شما نمی‌توانید حساب خودتان را غیرفعال کنید."

#: app/views/users.py:368
#, python-format
msgid "MFA disabled for user '%(username)s'."
msgstr "MFA برای کاربر '%(username)s' غیرفعال شد."

#: app/views/users.py:374
msgid "An error occurred while resetting MFA."
msgstr "خطایی در هنگام حذف کاربر رخ داد."

