msgstr "인증기에서 코드를 입력해야 합니다."

#: app/views/mfa.py:82 app/views/mfa.py:259
msgid "Invalid code. Please try again."
msgstr "잘못된 코드입니다. 다시 시도하세요."

#: app/views/mfa.py:91
msgid "Two-factor authentication disabled."
msgstr "알림이 비활성화되었습니다"

#: app/views/mfa.py:132
msgid "Recovery codes are only shown immediately after enabling MFA."
msgstr "복구 코드는 MFA 활성화 직후에만 표시됩니다."

#: app/views/mfa.py:142
msgid "Could not load recovery codes."
msgstr "복구 코드를 불러올 수 없습니다."

