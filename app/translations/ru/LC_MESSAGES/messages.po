#: app/templates/admin/partials/help_panel.html:8
msgid "Fill in a unique username, valid email, and strong password."
msgstr ""
"Введите уникальное имя пользователя, действующий адрес электронной почты и "
"надежный пароль."

#: app/templates/admin/partials/help_panel.html:10
msgid "Assign a role:"
