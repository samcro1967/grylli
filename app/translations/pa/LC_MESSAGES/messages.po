msgid "In what city were you born?"
msgstr "ਤੁਹਾਡਾ ਜਨਮ ਕਿਸ ਸ਼ਹਿਰ ਵਿੱਚ ਹੋਇਆ ਸੀ?"

#: app/forms/security_questions_form.py:20
msgid "What is the name of your childhood best friend?"
msgstr "ਤੁਹਾਡੇ ਬਚਪਨ ਦੇ ਸਭ ਤੋਂ ਚੰਗੇ ਦੋਸਤ ਦਾ ਕੀ ਨਾਮ ਹੈ?"

#: app/forms/security_questions_form.py:21
msgid "What was the mascot of the high school you graduated from?"
msgstr "ਤੁਹਾਡੇ ਮੈਟ੍ਰਿਕ ਵਿਦਿਆਲਯ ਦਾ ਮਸਕੌਟ ਕੀ ਸੀ?"

#: app/forms/security_questions_form.py:22
msgid "What is the name of the first elementary school you attended?"
msgstr "ਤੁਹਾਡੇ ਪਹਿਲੇ ਪ੍ਰਾਥਮਿਕ ਸਕੂਲ ਦਾ ਕੀ ਨਾਮ ਸੀ ਜਿੱਥੇ ਤੁਸੀਂ ਪੜ੍ਹਾਈ ਕੀਤੀ ਸੀ?"

#: app/forms/security_questions_form.py:23
msgid "What is your mother’s maiden name?"
msgstr "ਤੁਹਾਡੀ ਮਾਤਾ ਦਾ ਕੁਵਾਰੀ ਨਾਂ ਕੀ ਹੈ?"

#: app/forms/security_questions_form.py:24
msgid "What is your maternal grandmother's maiden name?"
msgstr "ਤੁਹਾਡੀ ਨਾਨੀ ਦਾ ਕੁਵਾਰੀ ਨਾਂ ਕੀ ਹੈ?"

#: app/forms/security_questions_form.py:25
