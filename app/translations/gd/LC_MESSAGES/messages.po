#: /home/osuhickeys/Documents/Docker/grylli/app/templates/index.html:27
msgid "Assign one or more delivery destinations."
msgstr "Sònraich aon no barrachd cheann-uidhe lìbhrigidh."

#: /home/osuhickeys/Documents/Docker/grylli/app/templates/index.html:28
msgid "Optionally attach files for secure emails."
msgstr "Roghainneil, ceangail faidhlichean airson puist-d tèarainte."

#: /home/osuhickeys/Documents/Docker/grylli/app/templates/index.html:29
msgid "Enable the message to start monitoring."
msgstr "Cuir comas air an teachdaireachd gus an sgrùdadh a thòiseachadh."

#: /home/osuhickeys/Documents/Docker/grylli/app/templates/index.html:30
msgid "If you don’t check in, Grylli delivers the message for you."
msgstr ""
"Mura cuir thu a-steach, bidh Grylli a’ lìbhrigeadh an teachdaireachd dhut."

