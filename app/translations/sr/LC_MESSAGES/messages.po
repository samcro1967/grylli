msgstr "Pristup pomoći za administratore"

#: app/templates/admin/help_form.html:9
msgid "Enter your Ferret Key to unlock admin-only help documentation."
msgstr ""
"Unesite svoj Ferret Key da biste otključali dokumentaciju pomoći koja je "
"dostupna samo administratorima."

#: app/templates/admin/help_form.html:47
