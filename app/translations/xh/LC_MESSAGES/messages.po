#: /home/osuhickeys/Documents/Docker/grylli/app/templates/about.html:10
msgid "About Grylli"
msgstr "Malunga neGrylli"

#: /home/osuhickeys/Documents/Docker/grylli/app/templates/about.html:13
msgid ""
"Grylli is a secure, self-hosted message delivery platform that automatically"
" sends pre-configured messages if a user fails to check in within a defined "
"time period."
msgstr ""
"Grylli liqonga elikhuselweyo, elizihambelayo lezazo ezithumela "
"ngokuzenzekelayo imiyalezo elungelelanisiweyo ukuba umsebenzisi akahloli "
"kwixesha elimisiweyo."

#: /home/osuhickeys/Documents/Docker/grylli/app/templates/about.html:14
msgid "It supports multiple users and customizable schedules."
msgstr "Isekela abasebenzisi abaninzi kunye nezicwangciso ezilungiselelwe."

#: /home/osuhickeys/Documents/Docker/grylli/app/templates/about.html:15
msgid ""
"Messages can be delivered via email, webhooks, or over 80 third-party "
"services through Apprise."
msgstr ""
"Imiyalezo ingathunyelwa nge-imeyile, ii-webhooks, okanye ngqo kwiinkonzo "
"ezingaphezulu kwe-80 zezithathu nge-Apprise."

#: /home/osuhickeys/Documents/Docker/grylli/app/templates/about.html:16
msgid ""
"Users can configure their own SMTP servers to ensure messages appear to come"
" directly from them — not from the system administrator."
msgstr ""
"Abasebenzisi bangahlela izizinda zabo ze-SMTP ukuqinisekisa ukuba imiyalezo "
"ibonakala ivela ngqo kubo - hayi kummkhandisi wenkqubo."

#: /home/osuhickeys/Documents/Docker/grylli/app/templates/about.html:17
msgid ""
"Sensitive data is encrypted at rest, and all message operations are secured "
"with strong authentication and audit-friendly logging."
msgstr ""
"Idatha eziphakamisileyo igqutywa ngokuphumla, kwaye yonke imisebenzi "
"yemiyalezo ikhuselekile ngesalathiso esomeleleyo nesihlalutyi esinobungqina."

#: /home/osuhickeys/Documents/Docker/grylli/app/templates/about.html:18
msgid ""
"Built with a modern, reactive technology stack, Grylli is optimized for "
"responsiveness and works seamlessly across desktop and mobile devices."
msgstr ""
"Yakhelwe ngesitaki seteknoloji esiphendulayo nesibuyekeza ngamaxesha, Grylli"
" ilungiselelwe ukubuyekezwa kwaye isebenza ngaphandle kweminxeba "
"kwiikhompuyutha nakwizinze eselula."

