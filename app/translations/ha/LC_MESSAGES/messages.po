#: app/templates/index.html:9 app/views/locale.py:95
msgid "Welcome to Grylli"
msgstr "Barka da zuwa Grylli"

#: app/templates/index.html:11
msgid "Pronounced"
msgstr "Kara shi"

#: app/templates/index.html:11
msgid "like “grill-ee”"
msgstr "kamar “grill-ee”"

#: app/templates/index.html:14
msgid ""
"Grylli is a secure message scheduling and delivery system designed to ensure"
" your important messages are delivered — even if you can’t be there to send "
"them."
msgstr ""
"Grylli tsarin tsaro ne na tsara saƙonni da isar da su wanda aka tsara don "
"tabbatar da cewa an isar da muhimman sakonninka — ko da ba za ka iya "
"kasancewa wajen isar da su ba."

#: app/templates/index.html:17
msgid ""
"Whether you’re planning ahead, setting up emergency communication, or "
"building peace of mind, Grylli helps automate your message delivery via "
"multiple channels including email, webhooks, and Apprise notifications."
msgstr ""
"Ko kana shirin gaba, saka tsarin sadarwar gaggawa, ko kuma gina natsuwa, "
"Grylli yana taimaka maka tsara isar da saƙonka ta hanyar imel, webhooks, ko "
"Apprise notifications idan ka rasa shiga."

#: app/templates/index.html:19
msgid "Getting Started"
msgstr "Fara"

#: app/templates/index.html:21
msgid "Create a message, email, or reminder."
msgstr "Ƙirƙiri sakon ko imel."

#: app/templates/index.html:22
msgid "Set your check-in interval and grace period (for messages)."
msgstr "Saita lokacin duba ka da lokacin gafara."

#: app/templates/index.html:23
msgid "Assign one or more delivery destinations."
msgstr "Aruutta uke me tonam ilpussolu piskatandi."

#: app/templates/index.html:24
msgid "Optionally attach files for secure emails."
msgstr "Zaɓi loda fayiloli don imel mai tsaro."

#: app/templates/index.html:25
msgid "Schedule reminders to send at specific times or on a recurring basis."
msgstr "Jadawalin tunatarwa don aiko a lokuta na musamman ko akai-akai."

#: app/templates/index.html:26
msgid "Enable the message or reminder to activate delivery."
msgstr "Bada saƙo ko tunatarwa don kunnawa isarwa."

#: app/templates/index.html:28
msgid ""
"Regularly check in to Grylli to prevent automated delivery; miss a check-in "
"and Grylli sends your messages as scheduled."
msgstr ""
"Yi duba Grylli akai a kai don hana aika da sakonni ta atomatik; idan ba a "
"duba Grylli ba, zai aika da sakonninka kamar yadda aka tsara."

#: app/templates/privacy.html:10
msgid "Privacy Notice"
msgstr "Avisu Privasidá"

#: app/templates/privacy.html:13
msgid ""
"Grylli respects your privacy and is designed to minimize the collection and "
"storage of personal data."
msgstr ""
"Grylli tôn trọng quyền riêng tư của bạn và được thiết kế để giảm thiểu việc "
"thu thập và lưu trữ dữ liệu cá nhân."

#: app/templates/privacy.html:14
msgid ""
"All data is encrypted where appropriate and remains fully under your control"
" if you self-host this platform."
msgstr ""
"Tất cả dữ liệu được mã hóa một cách thích hợp và bạn hoàn toàn kiểm soát nếu"
" tự lưu trữ nền tảng này."

#: app/templates/privacy.html:17
msgid "What Data We Collect"
msgstr "Dữ liệu chúng tôi thu thập"

#: app/templates/privacy.html:19
msgid "Email address and password hash (for authentication)"
msgstr "Địa chỉ email và mã băm mật khẩu (dùng để xác thực)"

#: app/templates/privacy.html:20
msgid "Optional MFA secret and recovery codes (encrypted at rest)"
msgstr "Mã MFA tuỳ chọn và mã khôi phục (được mã hóa khi lưu trữ)"

#: app/templates/privacy.html:21
msgid "Reminder and message content you configure"
msgstr "Nội dung nhắc nhở và tin nhắn bạn cấu hình"

#: app/templates/privacy.html:22
msgid "User-specific settings, SMTP configuration (if provided)"
msgstr "Cài đặt người dùng cụ thể, cấu hình SMTP (nếu có cung cấp)"

#: app/templates/privacy.html:25
msgid "How Your Data Is Used"
msgstr "Cách dữ liệu của bạn được sử dụng"

#: app/templates/privacy.html:27
msgid ""
"Your data is used solely for the purpose of delivering reminders and "
"messages according to your preferences."
msgstr ""
"Dữ liệu của bạn chỉ được sử dụng để gửi nhắc nhở và tin nhắn theo tùy chọn "
"của bạn."

#: app/templates/privacy.html:28
msgid ""
"Grylli does not share, sell, or transmit your personal data to any third "
"parties."
msgstr ""
"Grylli không chia sẻ, bán hoặc truyền dữ liệu cá nhân của bạn cho bất kỳ bên"
" thứ ba nào."

#: app/templates/privacy.html:31
msgid "Your Rights"
msgstr "Quyền của bạn"

#: app/templates/privacy.html:33
msgid ""
"You can export all of your data at any time from the Account Settings page."
msgstr ""
"Bạn có thể xuất toàn bộ dữ liệu của mình bất kỳ lúc nào từ trang Cài đặt Tài"
" khoản."

#: app/templates/privacy.html:34
msgid "You may permanently delete your account and all associated data."
msgstr "Ba za ku iya goge asusunku ba saboda ku ne admin na karshe."

#: app/templates/privacy.html:35
msgid ""
"If you are using a self-hosted instance, contact the instance administrator "
"for data inquiries."
msgstr ""
"Nếu bạn đang sử dụng một phiên bản tự lưu trữ, hãy liên hệ với quản trị viên"
" phiên bản để yêu cầu dữ liệu."

#: app/templates/privacy.html:38
msgid "Self-Hosting Responsibility"
msgstr "Trách nhiệm tự lưu trữ"

#: app/templates/privacy.html:40
msgid ""
"If you are running Grylli on your own server, you are responsible for the "
"storage, processing, and lawful handling of all user data on that instance."
msgstr ""
"Nếu bạn đang chạy Grylli trên máy chủ của riêng mình, bạn chịu trách nhiệm "
"về việc lưu trữ, xử lý và xử lý hợp pháp tất cả dữ liệu người dùng trên "
"phiên bản đó."

#: app/templates/privacy.html:44
msgid ""
"This notice was last updated in June 2025 and may evolve to reflect changes "
"in the software or regulatory landscape."
msgstr ""
"Thông báo này đã được cập nhật lần cuối vào tháng 6 năm 2025 và có thể phát "
"triển để phản ánh những thay đổi trong phần mềm hoặc bối cảnh pháp lý."

