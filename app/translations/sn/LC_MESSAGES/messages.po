msgid "Use your own email server"
msgstr "Shandisa server yako yeemail"

#: app/templates/help.html:22
msgid "Apprise Integration"
msgstr "Apprise Nzvimbo"

#: app/templates/help.html:24
msgid "Send notifications to 80+ supported services"
msgstr "Tumira ziviso kumasevhisi anotsigirwa makumi masere nemasere"

